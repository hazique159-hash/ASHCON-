# ─────────────────────────── App ───────────────────────────
NODE_ENV=development
APP_NAME=Connect Affairs
APP_URL=http://localhost:5173
API_PORT=4000
TZ=Asia/Karachi

# ───────────────────────── Database ─────────────────────────
DATABASE_URL=postgresql://ashcon:ashcon@localhost:5432/connect_affairs?schema=public

# ─────────────────────────── Auth ───────────────────────────
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_REFRESH_SECRET=replace-with-different-strong-random-secret
ACCESS_TTL=15m
REFRESH_IDLE_TTL=8h
REFRESH_ABSOLUTE_TTL=7d
BCRYPT_COST=11
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION=15m
PASSWORD_MIN_LENGTH=12
PASSWORD_HISTORY=5
ENCRYPTION_KEY=replace-with-32-byte-base64-key
MFA_ISSUER=Connect Affairs

# ───────────────── Seed admin (first run only) ─────────────────
SEED_ADMIN_EMAIL=admin@ashcon.local
SEED_ADMIN_PASSWORD=replace-with-strong-password

# ───────────────────────── Storage ─────────────────────────
STORAGE_DRIVER=local            # local | s3
STORAGE_LOCAL_PATH=./storage
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─────────────────── Mail (nodemailer / SMTP) ───────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Connect Affairs <no-reply@ashcon.local>

# ──────────────────── SMS (ready, disabled) ────────────────────
SMS_ENABLED=false
SMS_PROVIDER=
SMS_API_KEY=
