{
  "name": "connect-affairs",
  "version": "0.1.0",
  "private": true,
  "description": "Connect Affairs — Enterprise Employee Management Portal for Ashcon Engineering",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:migrate": "pnpm --filter @ca/api db:migrate",
    "db:seed": "pnpm --filter @ca/api db:seed"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
