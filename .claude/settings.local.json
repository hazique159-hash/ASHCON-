{
  "permissions": {
    "allow": [
      "mcp__visualize__read_me",
      "mcp__visualize__show_widget",
      "Bash(npm -v)",
      "Bash(pnpm -v)",
      "Bash(git --version)",
      "Bash(docker -v)",
      "Bash(corepack enable *)",
      "PowerShell(pnpm install 2>&1)",
      "PowerShell(pnpm --filter @ca/api exec prisma migrate dev --name init --skip-seed)",
