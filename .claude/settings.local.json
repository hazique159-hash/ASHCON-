      "PowerShell(pnpm --filter @ca/api exec node scripts/reset-db.mjs)",
      "PowerShell(pnpm --filter @ca/api exec prisma migrate deploy)",
      "PowerShell(pnpm --filter @ca/api db:seed:demo)",
      "PowerShell(pnpm --filter @ca/ui typecheck)",
      "PowerShell(pnpm --filter @ca/web typecheck)",
      "PowerShell(pnpm --filter @ca/api typecheck)",
      "PowerShell(pnpm --filter @ca/ui add \"@radix-ui/react-tabs\" \"@radix-ui/react-select\" 2>&1)",
      "PowerShell(pnpm --filter @ca/contracts typecheck)"
    ]
  }
}
